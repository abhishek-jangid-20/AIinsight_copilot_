# Gateway
NODE_ENV=development
PORT=8080
CLIENT_ORIGIN=http://localhost:5173
JWT_SECRET=change-me-in-production
MONGODB_URI=mongodb://mongo:27017/codeinsight

# AI services
PARSER_SERVICE_URL=http://repository-parser-service:8101
EMBEDDING_SERVICE_URL=http://embedding-service:8102
RAG_SERVICE_URL=http://rag-service:8103
DOCUMENTATION_SERVICE_URL=http://documentation-service:8104
ANALYSIS_SERVICE_URL=http://analysis-service:8105
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# LLM providers, choose one or more
LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
